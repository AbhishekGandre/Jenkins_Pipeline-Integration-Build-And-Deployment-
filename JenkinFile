pipeline {
    agent any // Specifies that the pipeline can run on any available agent

    tools {
        maven 'maven' // Assumes you have configured a Maven installation named 'localMaven' in 'Manage Jenkins' -> 'Global Tool Configuration'
        jdk 'JDK' // Assumes you have configured a JDK installation named 'jdk17'
    }
 environment {
        TOMCAT_HOME = 'C:\\Users\\Abhishek\\Desktop\\Jenkins\\apache-tomcat-9.0.115\\apache-tomcat-9.0.115'
    }

    stages {
      stage('Clone Repository') {
            steps {
                git branch: 'main', url: 'https://github.com/AbhishekGandre/MavenWar.git'
            }
        }
      
      stage('Build WAR') {
            steps {
                bat 'mvn clean package'
            }
        }

        stage('Archive WAR') {
            steps {
                archiveArtifacts artifacts: 'target/*.war', fingerprint: true
            }
        } 
       stage('Deploy to Tomcat') {
            steps {
                bat 'copy target\\*.war %TOMCAT_HOME%\\webapps\\'
            }
        }
      
      
    }
}
